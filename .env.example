# Local dev / build environment.
#
# Quick start (Daniel): copy this file to ".env" and you're done -
#   Bash/macOS:   cp .env.example .env
#   PowerShell:   Copy-Item .env.example .env
# then `npm run dev`. The app needs VITE_SUPABASE_URL + VITE_SUPABASE_PUBLISHABLE_KEY
# or the loading spinner stays stuck (can't reach Supabase).
#
# All values below are PUBLIC build-time values - the anon/publishable key is the
# public Supabase key (RLS protects the data), and these are embedded in the browser
# bundle anyway. So it is safe to keep them here. Do NOT add any service-role key,
# Personal Access Token, or other secret to this file.
#
# NOTE the exact variable names: the client reads VITE_SUPABASE_PUBLISHABLE_KEY
# (NOT VITE_SUPABASE_ANON_KEY). See src/integrations/supabase/client.ts.

VITE_SUPABASE_PROJECT_ID="ytqgeoviokgxxwalieev"
VITE_SUPABASE_URL="https://ytqgeoviokgxxwalieev.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl0cWdlb3Zpb2tneHh3YWxpZWV2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzEzMTA0NjYsImV4cCI6MjA4Njg4NjQ2Nn0.jeSSSbTP3CbKVjlzqlYavwoGqooLW7bLV9JQTY9RhD8"
VITE_WEBSITE_URL="siango.app"
# Server-side only (read via Deno.env in orders-create + payments-callback). Set
# it as a Supabase Edge Function secret, NOT here. Placeholder shown for shape.
VITE_ORDER_WEBHOOK_URL="https://hook.eu2.make.com/your-scenario-id"
